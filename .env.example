# DigitalOcean Gradient AI — get from cloud.digitalocean.com/gen-ai
GRADIENT_API_KEY=your_gradient_api_key_here
GRADIENT_BASE_URL=https://inference.do-ai.run/v1
GRADIENT_WORKSPACE_ID=your_workspace_id_here
LLM_MODEL=llama3-1-70b-instruct
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# Database (auto-configured in docker-compose)
DATABASE_URL=postgresql+asyncpg://omnimind:omnimind@postgres:5432/omnimind

# Redis (auto-configured in docker-compose)
REDIS_URL=redis://redis:6379

# Qdrant (auto-configured in docker-compose)
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=omnimind_knowledge
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
